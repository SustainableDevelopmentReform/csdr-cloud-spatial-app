{
  "name": "@repo/server",
  "version": "0.0.0",
  "exports": {
    "./app": {
      "import": {
        "types": "./dist/types/app.d.ts"
      }
    },
    "./hc": {
      "import": {
        "types": "./dist/types/hc.d.ts"
      }
    },
    "./schemas/zod": {
      "import": {
        "types": "./dist/types/schemas/zod.d.ts"
      }
    }
  },
  "scripts": {
    "start": "NODE_ENV=production tsx src/index.ts",
    "dev": "pnpm --filter @repo/server --parallel \"/^dev:.*/\"",
    "dev:types": "tsc -p tsconfig.build-types.json --watch",
    "dev:server": "tsx watch src/index.ts",
    "build": "pnpm build:types && pnpm --filter @repo/server --parallel \"/^build:distributable.*/\"",
    "build:distributable-app": "ncc build src/index.ts -o dist/app -m -s",
    "build:distributable-scripts": "ncc build scripts/migrate.ts -o dist/migrate -m && ncc build scripts/seed.ts -o dist/seed -m",
    "build:types": "tsc -p tsconfig.build-types.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "create:migration": "drizzle-kit generate",
    "drizzle-studio": "drizzle-kit studio",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:dev": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:dev": "tsx scripts/seed.ts",
    "test:unit": "tsx scripts/pretest.ts && vitest run"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/eslint": "catalog:",
    "@types/node": "catalog:",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.11",
    "@types/react": "catalog:react19",
    "@types/simple-oauth2": "^5.0.7",
    "@vercel/ncc": "^0.38.3",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "^3.0.6"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-storage": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-openapi": "catalog:",
    "@hono/zod-validator": "^0.7.3",
    "@repo/schemas": "workspace:*",
    "@react-email/components": "^0.0.33",
    "@scalar/hono-api-reference": "^0.9.19",
    "@t3-oss/env-core": "^0.13.8",
    "better-auth": "catalog:",
    "chalk": "^5.4.1",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.5",
    "hono": "catalog:",
    "nanoid": "^5.1.0",
    "nodemailer": "^6.10.0",
    "pg": "^8.13.3",
    "rate-limiter-flexible": "^5.0.5",
    "react": "catalog:react19",
    "simple-oauth2": "^5.1.0",
    "tsx": "^4.19.3",
    "uuid": "^11.1.0",
    "zod": "catalog:",
    "zod-geojson": "^1.0.0"
  }
}
