{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "@repo/schemas/*": [
        "../../packages/schemas/src/*"
      ]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "incremental": true,
    "strict": true
  },
  "include": [
    "src/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
