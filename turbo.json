{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build:types": {
      "outputs": [
        "dist/types/**"
      ]
    },
    "build": {
      "dependsOn": [
        "^build",
        "build:types"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": [
        ".env*"
      ]
    },
    "create:migration": {
      "inputs": [
        ".env*"
      ],
      "cache": false,
      "persistent": true
    },
    "migrate": {
      "inputs": [
        ".env*"
      ],
      "cache": false
    },
    "seed": {
      "inputs": [
        ".env*"
      ],
      "cache": false
    },
    "drizzle-studio": {
      "inputs": [
        ".env*"
      ],
      "cache": false
    },
    "test:unit": {
      "inputs": [
        ".env*"
      ],
      "persistent": true
    }
  },
  "globalEnv": [
    "APP_URL",
    "INTERNAL_FRONTEND_URL",
    "INTERNAL_BACKEND_URL",
    "TRUSTED_ORIGINS",
    "DEV_USE_INTERNAL_BACKEND_URL_IN_FRONTEND",
    "DATABASE_URL",
    "S3_BUCKET_NAME",
    "S3_SPACES_ENDPOINT",
    "S3_SPACES_SECRET_KEY",
    "S3_SPACES_ACCESS_KEY_ID",
    "SMTP_PASSWORD",
    "SMTP_USERNAME",
    "SMTP_HOST",
    "SMTP_PORT",
    "EMAIL_SENDER",
    "EMAIL_CATCHER",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_REDIRECT_URI",
    "INITIAL_USER_EMAIL",
    "INITIAL_USER_NAME",
    "INITIAL_USER_PASSWORD",
    "AUTH_REQUIRE_EMAIL_VERIFICATION"
  ]
}
